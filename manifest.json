{
  "manifest_version": 3,
  "name": "Simple WhatsApp Auto Responder",
  "version": "1.0.0",
  "description": "Responde automáticamente a mensajes que contienen una palabra clave.",
  "permissions": ["storage"],
  "host_permissions": ["https://web.whatsapp.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Auto Responder"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
